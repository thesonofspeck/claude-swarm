{
  "permissions": {
    "allow": [
      "Read(./.claude/memory/**)",
      "Write(./.claude/memory/**)",
      "Edit(./.claude/memory/**)",
      "Bash(grep:./.claude/memory/**)",
      "Bash(ls:./.claude/memory/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{POLICY_SCRIPT}}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{NOTIFY_SCRIPT}} Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{NOTIFY_SCRIPT}} Stop"
          }
        ]
      }
    ]
  }
}
